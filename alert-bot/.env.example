# Токен Telegram-бота — получить у @BotFather (обязательно)
BOT_TOKEN=1234567890:AAAA...

# Токен API alerts.in.ua (желательно, но необязательно).
# Запросить бесплатно: https://alerts.in.ua (раздел API / devs.alerts.in.ua)
# Без него бот работает через резервный источник (только факт тревоги).
ALERTS_IN_UA_TOKEN=

# Период опроса API в секундах (минимум 15)
POLL_INTERVAL=30

# Файл базы данных подписчиков
DB_PATH=alertbot.sqlite3
